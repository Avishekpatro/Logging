#!/bin/sh
# Runs before each commit; prints AI efficiency only when there are Cursor AI edits to measure.
# Enable once per clone:  git config core.hooksPath .githooks
#                          chmod +x .githooks/pre-commit
set -eu

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$ROOT"

mvn -f ai-metrics-forwarder-java/pom.xml -q compile exec:java -Dexec.args="--commit --no-otel" 2>&1 \
  || echo "[cursor-ai] Efficiency step failed (commit continues)." >&2

exit 0
